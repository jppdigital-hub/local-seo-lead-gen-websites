# Copy this to .env.local and fill in your values

# Make.com webhook — receives all lead form submissions from the contact/quote form
# This is your live "Rank & Rent Lead Router" scenario webhook
LEAD_WEBHOOK_URL=https://hook.us2.make.com/z95cg8lqlgbpwt1hu1n8uyg2l87hxhf3

# Cloudflare Turnstile — bot protection for the lead form
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Leave blank to disable Turnstile (form will still use honeypot + scoring)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
